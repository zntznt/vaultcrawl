      "lines": {
        "discipline": [
          "Freedom is downstream of discipline.",
          "that protects me by Friday.",
          "Small repeated acts compound into a self."
        ],
        "journaling": [
          "Writing is how I find out what I think.",
          "The page is a mirror that talks back.",
          "entry is less about the record and more about the act of noticing.",
          "This is also where my inner life meets my systems — see Second Brain."
        ],
        "memento mori": [
          "Remember that you will die.",
          "Not as morbidity but as a lens that sharpens attention.",
          "The hours are not infinite, so the trivial loses its grip."
        ],
        "second brain": [
          "The vault is a second brain: notes as nodes, links as thought.",
          "that structure emerges — clusters form around obsessions without me planning them.",
          "This idea bridges my inner practice and my making."
        ],
        "stoicism": [
          "The practice of separating what is in my control from what is not.",
          "follows from that one cut."
        ]
      }
